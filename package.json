{
  "name": "lkphone-server",
  "version": "1.0.0",
  "description": "Backend server for LKphone app",
  "main": "index.js",
  "scripts": {
    "dev": "wrangler dev",
    "cf-typegen": "wrangler types",
    "db:migrate": "wrangler d1 migrations apply DB --remote",
    "db:repair-groups": "wrangler d1 execute DB --remote --file scripts/repair-mixed-groups.sql",
    "deploy": "wrangler d1 migrations apply DB --remote && wrangler deploy"
  },
  "dependencies": {
    "hono": "^4.0.0",
    "@cloudflare/workers-types": "^4.0.0"
  },
  "devDependencies": {
    "wrangler": "^4.95.0"
  }
}
